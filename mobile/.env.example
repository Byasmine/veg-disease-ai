# API base URL for the backend. Loaded at start via app.config.js.
# Leave unset for local dev (defaults to http://localhost:8000).
# For production or device testing, set to your Railway (or other) backend URL.
# You can omit https:// — it will be added automatically.
# EXPO_PUBLIC_API_URL=https://your-app.up.railway.app
# EXPO_PUBLIC_API_URL=your-app.up.railway.app
