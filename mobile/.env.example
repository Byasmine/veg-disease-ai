# AI backend base URL (diagnosis APIs)
# EXPO_PUBLIC_API_URL=https://your-ai-backend.up.railway.app

# Shop backend base URL (catalog + cart/orders + JWT auth: /api/auth, /api/shop)
# EXPO_PUBLIC_SHOP_API_URL=http://localhost:8082
# EXPO_PUBLIC_SHOP_API_URL=https://your-shop-backend.up.railway.app
#
# Android: localhost in .env is rewritten to 10.0.2.2 in the app (emulator → host PC only).
# On a physical phone, set EXPO_PUBLIC_* URLs to your PC's LAN IP (e.g. http://192.168.1.10:8082).
# After changing .env: npx expo start -c
