# Optional: LLM reasoning (POST /predict-with-reasoning)
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
# Or use Groq (OpenAI-compatible)
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: Cloudinary (image storage for feedback). If not set, feedback images are NOT uploaded.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=veg-disease

# Optional: Pinecone (vector DB for RAG)
PINECONE_API_KEY=
PINECONE_INDEX_NAME=veg-disease-knowledge
PINECONE_HOST=
PINECONE_NAMESPACE=default
EMBEDDING_MODEL=text-embedding-3-small

# Retraining pipeline (MLOps)
MIN_RETRAINING_SAMPLES=50
WEAKNESS_LABEL_THRESHOLD=20
MIN_IMAGE_RESOLUTION=128
