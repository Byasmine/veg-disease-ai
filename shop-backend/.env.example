PORT=8082
# Listen on all interfaces so Android emulator (10.0.2.2) and LAN devices can connect. Default in code is 0.0.0.0.
# HOST=0.0.0.0

# PostgreSQL (Railway provides DATABASE_URL when you add a Postgres plugin)
DATABASE_URL=postgresql://shop:shop@localhost:5433/shop

# Required: random secret for signing JWTs (min 16 chars). Generate e.g. openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string

# Optional token lifetime (default 7d)
# JWT_EXPIRES_IN=7d

# Public URL of this API (for avatar links). On Railway set to your service URL.
# PUBLIC_BASE_URL=http://localhost:8082

# Email (OTP). If omitted, OTPs are printed to the server console (dev only).
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# Note: 587 = STARTTLS (secure must be false). 465 = SSL from connect (secure true). Mixing 587 + secure true causes OpenSSL "wrong version number".
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=Leaf Doctor <noreply@yourdomain.com>

# SSL for hosted Postgres (Railway/Heroku). Default: verify TLS unless DATABASE_SSL=false
# DATABASE_SSL=false
# DATABASE_SSL_REJECT_UNAUTHORIZED=false

# Dev only: wipe shop catalog + carts on startup, then re-seed from data/*.json (do not use in production)
# CATALOG_RESET=true
